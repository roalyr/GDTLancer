[sub_resource type="GDScript" id=2]
script/source = "extends Button

var icon_untoggled =  load(\"res://Assets/UI_images/PNG/buttons/controls_swap.png\")
var icon_toggled = load(\"res://Assets/UI_images/PNG/buttons/controls_swap_toggled.png\")

func _on_Button_controls_swap_toggled(button_pressed):
	if button_pressed:
		self.icon = icon_toggled
	else:
		self.icon = icon_untoggled
"

