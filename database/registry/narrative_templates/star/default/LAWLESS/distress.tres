[resource]
script = ExtResource( 1 )
template_id = "narrative_rescue_lawless"
title = "Degraded Hailer Signal"
body_text = "A weak comms-scratch cuts through the static. A stranded iron-scow's crew is sweating vacuum out in the lawless drift, their hull buckling under thermal strain. They are offering their remaining heavy-water cache in exchange for a tow back to the enclaves."
creole_dialect = "Pragmatic Creole"
