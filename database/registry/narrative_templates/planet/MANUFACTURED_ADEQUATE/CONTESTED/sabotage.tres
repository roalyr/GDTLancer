script = ExtResource( 1 )
template_id = "narrative_sabotage_contested"
title = "Crippled Processing Line"
body_text = "Tensions between local assembly families on the manufacturing deck have boiled over. The main breaker-rig power line has been cut, halting assembly. The deck foreman is looking for independent hands to mediate or secure the repair site before the watchkeep shuts the whole sector down."
creole_dialect = "Pragmatic Creole"
